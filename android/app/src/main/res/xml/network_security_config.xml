<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: HTTPS only — all traffic routes through the Render backend -->
    <!-- No cleartext (HTTP) traffic permitted on any domain -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">web-production-259f33.up.railway.app</domain>
    </domain-config>
</network-security-config>
