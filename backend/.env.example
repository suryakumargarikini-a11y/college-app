# SITAM Smart ERP - Backend Environment Configuration

# Service Ports
PORT=3001
NODE_ENV=production

# URLs for APIs and ERP Scrapers
API_BASE_URL=http://localhost:3001/api
ERP_BASE_URL=https://sitamecap.co.in/SATYA

# Database & Cache Providers
# (For SQLite dev, use "file:./dev.db". For PostgreSQL prod, specify connection URL)
DATABASE_URL="postgresql://sitam:sitam_secure_pass@localhost:5432/sitam_db?schema=public"
REDIS_URL="redis://localhost:6379"

# Firebase Cloud Messaging Credentials (for push alerts)
FCM_PROJECT_ID=sitam-erp-project
FCM_CLIENT_EMAIL=firebase-adminsdk@sitam-erp-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC..."

# JWT Access tokens encryption key
JWT_SECRET=sitam_campus_jwt_secret_token_entropy_pool_key

# Logging Configuration
LOG_LEVEL=info

# Versioning Configuration
APP_VERSION=1.0.0

# CORS Allowed Origins (comma-separated list of domains)
ALLOWED_ORIGINS=http://localhost:3000,https://sitam-erp.vercel.app,capacitor://localhost
