# SITAM Smart ERP - Backend Environment Configuration (Local Development Template)
# NOTE: This file is a template. Copy it to .env and configure local values.
# Real credentials must never be committed to Git.

# Service Ports
PORT=8080
NODE_ENV=development

# URLs for APIs and ERP Scrapers
API_BASE_URL=https://your-backend-service.up.railway.app/api
ERP_BASE_URL=https://sitamecap.co.in/SATYA

# Database & Cache Providers
# (For SQLite dev, use "file:./dev.db". For PostgreSQL dev, specify connection URL)
DATABASE_URL="postgresql://your_db_user:your_db_password@localhost:5432/your_db_name?schema=public"
REDIS_URL="redis://localhost:6379"

# Firebase Cloud Messaging Credentials (for push alerts)
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=your-firebase-adminsdk-email@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_MOCK_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# JWT Access tokens encryption key
JWT_SECRET=your_secure_jwt_secret_token_key_here

# Logging Configuration
LOG_LEVEL=info

# Versioning Configuration
APP_VERSION=1.0.0

# CORS Allowed Origins (comma-separated list of domains)
ALLOWED_ORIGINS=http://localhost:3000,https://sitam-erp.vercel.app,capacitor://localhost
