      "id": 4,
      "title": "Slow Traces / SLO Violations (>1s threshold)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_bucket{le=\"1.0\"}[1m]))",
          "legendFormat": "Under 1s SLO",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_request_duration_seconds_count[1m])) - sum(rate(http_request_duration_seconds_bucket{le=\"1.0\"}[1m]))",
          "legendFormat": "SLO Violations (>1s)",
          "refId": "B"
        }
      ]
    },
