      "id": 5,
      "title": "Trace Anomaly Detection Frequency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(postgres_slow_queries_total[5m]))",
          "legendFormat": "DB Slow Query Anomalies",
          "refId": "A"
        },
        {
          "expr": "sum(rate(redis_reconnect_total[5m]))",
          "legendFormat": "Redis Reconnect Spikes",
          "refId": "B"
