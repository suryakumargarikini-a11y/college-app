{
  "uid": "synthetic-monitoring-v1",
  "title": "Synthetic Monitoring & SLO Status",
  "tags": ["synthetic", "slo", "reliability", "sitam"],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "title": "Synthetic Probe Success Rate — Overall",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [{ "expr": "sum(rate(synthetic_probe_success_total[5m])) / (sum(rate(synthetic_probe_success_total[5m])) + sum(rate(synthetic_probe_failure_total[5m]))) * 100", "legendFormat": "Success Rate" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"orange","value":90},{"color":"yellow","value":95},{"color":"green","value":99}] } } }
    },
    {
      "id": 2, "title": "ERP Availability (Synthetic)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 3 },
      "targets": [{ "expr": "rate(synthetic_probe_success_total{probe=\"erp_availability\"}[5m]) / (rate(synthetic_probe_success_total{probe=\"erp_availability\"}[5m]) + rate(synthetic_probe_failure_total{probe=\"erp_availability\"}[5m])) * 100", "legendFormat": "ERP Available" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":95}] } } }
    },
    {
      "id": 3, "title": "API Health Probe",
      "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 3 },
      "targets": [{ "expr": "rate(synthetic_probe_success_total{probe=\"api_health\"}[5m]) / (rate(synthetic_probe_success_total{probe=\"api_health\"}[5m]) + rate(synthetic_probe_failure_total{probe=\"api_health\"}[5m]) + 0.0001) * 100", "legendFormat": "API Health" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":99}] } } }
    },
    {
      "id": 4, "title": "Redis Connectivity Probe",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 3 },
      "targets": [{ "expr": "rate(synthetic_probe_success_total{probe=\"redis_connectivity\"}[5m]) / (rate(synthetic_probe_success_total{probe=\"redis_connectivity\"}[5m]) + rate(synthetic_probe_failure_total{probe=\"redis_connectivity\"}[5m]) + 0.0001) * 100", "legendFormat": "Redis" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":99}] } } }
    },
    {
      "id": 5, "title": "Queue Health Probe",
      "type": "stat",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 3 },
      "targets": [{ "expr": "rate(synthetic_probe_success_total{probe=\"queue_health\"}[5m]) / (rate(synthetic_probe_success_total{probe=\"queue_health\"}[5m]) + rate(synthetic_probe_failure_total{probe=\"queue_health\"}[5m]) + 0.0001) * 100", "legendFormat": "Queue" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":99}] } } }
    },
    {
      "id": 6, "title": "Notification Service Probe",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 3, "h": 3 },
      "targets": [{ "expr": "rate(synthetic_probe_success_total{probe=\"notification_service\"}[5m]) / (rate(synthetic_probe_success_total{probe=\"notification_service\"}[5m]) + rate(synthetic_probe_failure_total{probe=\"notification_service\"}[5m]) + 0.0001) * 100", "legendFormat": "Notifications" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"green","value":99}] } } }
    },
    {
      "id": 7, "title": "Synthetic Probe Duration (P95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(synthetic_probe_duration_seconds_bucket[5m]))", "legendFormat": "{{probe}} P95" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8, "title": "Probe Failures Timeline",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(synthetic_probe_failure_total[5m])", "legendFormat": "{{probe}} Failures/sec" }]
    },
    {
      "id": 9, "title": "SLO — API Success Rate",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 6 },
      "targets": [{ "expr": "slo_compliance_rate{slo=\"api_success_rate\"} * 100", "legendFormat": "API SLO" }],
      "fieldConfig": { "defaults": { "min": 99, "max": 100, "unit": "percent", "thresholds": { "steps": [{"color":"red","value":99},{"color":"yellow","value":99.5},{"color":"green","value":99.9}] } } }
    },
    {
      "id": 10, "title": "SLO — Sync Success Rate",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 6 },
      "targets": [{ "expr": "slo_compliance_rate{slo=\"sync_success_rate\"} * 100", "legendFormat": "Sync SLO" }],
      "fieldConfig": { "defaults": { "min": 95, "max": 100, "unit": "percent", "thresholds": { "steps": [{"color":"red","value":95},{"color":"yellow","value":98},{"color":"green","value":99}] } } }
    },
    {
      "id": 11, "title": "SLO Error Budget Remaining",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "targets": [{ "expr": "slo_error_budget_remaining{slo=~\".+\"}", "legendFormat": "{{slo}}" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{"color":"red","value":0},{"color":"orange","value":10},{"color":"yellow","value":30},{"color":"green","value":60}] } } },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 12, "title": "SLO Burn Rate (6h Window)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [{ "expr": "slo_burn_rate{window=\"6h\"}", "legendFormat": "{{slo}} 6h burn" }],
      "fieldConfig": { "defaults": { "custom": { "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"red","value":5}] } } }
    }
  ],
  "time": { "from": "now-12h", "to": "now" },
  "schemaVersion": 38,
  "version": 1
}
