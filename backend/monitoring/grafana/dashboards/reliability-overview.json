      "id": 1,
      "title": "Global Reliability Index",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 - (100 * (rate(http_requests_total{status=~\"5..\"}[5m]) or vector(0)) / (rate(http_requests_total[5m]) or vector(1)))",
          "legendFormat": "Uptime",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "SLO Uptime Burn Rate (1h)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[1h]) / 0.001",
          "legendFormat": "Burn Rate Factor",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "title": "Queue Saturation & Drift Forecasting",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "bullmq_jobs_waiting{queue=\"sitam-sync\"}",
          "legendFormat": "Waiting Sync Jobs",
          "refId": "A"
        },
        {
          "expr": "predict_linear(bullmq_jobs_waiting{queue=\"sitam-sync\"}[5m], 600)",
          "legendFormat": "Forecast Waiting Jobs (10m)",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "title": "Browser Pool Utilization & Crash Rates",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "browser_pool_active_contexts",
          "legendFormat": "Active Checked-out Contexts",
          "refId": "A"
        },
        {
          "expr": "browser_pool_active_browsers",
          "legendFormat": "Running Browsers",
          "refId": "B"
        },
        {
          "expr": "rate(browser_crashes_total[5m]) * 100",
          "legendFormat": "Browser Crashes (Rate)",
          "refId": "C"
