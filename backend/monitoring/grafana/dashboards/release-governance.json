{
  "uid": "release-governance-v1",
  "title": "CI/CD Release Governance Gates",
  "tags": ["sre", "cicd", "release", "governance", "sitam"],
  "timezone": "browser",
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Release Risk Index",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "release_governance_risk_index",
          "legendFormat": "Risk Index"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 20, "color": "orange" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Deployment Gate Status",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "deployment_safety_status",
          "legendFormat": "Gate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "orange" },
              { "value": 2, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Incidents Blockers",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(incident_active_count{severity=~\"SEV1|SEV2\"})",
          "legendFormat": "Critical Blockers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
