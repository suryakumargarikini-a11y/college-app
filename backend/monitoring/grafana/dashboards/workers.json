    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "title": "Worker Job Processing Latency (Seconds)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "worker_job_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "{{jobType}} job latency p95",
          "refId": "A"
        },
        {
          "expr": "worker_job_duration_seconds{quantile=\"0.5\"}",
          "legendFormat": "{{jobType}} job latency p50",
          "refId": "B"
        }
      ]
