{
  "uid": "executive-observability-v1",
  "title": "Executive Platform Health Dashboard",
  "tags": ["executive", "observability", "health", "sitam"],
  "timezone": "browser",
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Overall Platform Score",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "compliance_score{framework=\"INTERNAL_CONTROLS\"}",
          "legendFormat": "Platform Health Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 75, "color": "orange" },
              { "value": 90, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Incidents",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(incident_active_count)",
          "legendFormat": "Incidents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Deployment Safety Status",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "deployment_safety_status",
          "legendFormat": "Safety Status"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "orange" },
              { "value": 2, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "SLO Compliance Rates",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "slo_compliance_ratio",
          "legendFormat": "{{slo_name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Active Users (DAU)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "active_users{period=\"daily\"}",
          "legendFormat": "DAU"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
